# Real Brevo API key — never expose this to the frontend
BREVO_API_KEY=your-brevo-api-key-here

# Shared secret sent by Lovable edge functions as x-proxy-key header
PROXY_SECRET=change-me-to-a-long-random-string

# Port the server listens on (default: 3000)
PORT=3000

# Max requests per IP per minute before returning 429 (default: 20)
RATE_LIMIT_MAX=20

# Violations before an IP is blacklisted entirely (default: 5)
BLACKLIST_THRESHOLD=5

# How long a blacklisted IP is blocked in ms (default: 600000 = 10 min)
BLACKLIST_DURATION_MS=600000

# Max simultaneous open connections — excess are dropped (default: 100)
MAX_CONNECTIONS=100

# Time the client has to send request headers in ms — slow-loris defence (default: 5000)
HEADERS_TIMEOUT_MS=5000

# Idle keep-alive connection timeout in ms (default: 30000)
KEEP_ALIVE_TIMEOUT_MS=30000
